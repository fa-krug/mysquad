{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MySquad",
  "version": "1.7.0",
  "identifier": "com.mysquad.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MySquad",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/pictures/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "mysquad"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxMzgwN0UzODc0ODc3MUIKUldRYmQwaUg0d2M0TVhZTXUzUTlObW1MSm1ld1dNM2ZqblRpRjNBeFdXckpaTTFFRmJDN3BGTjcK",
      "endpoints": [
        "https://github.com/fa-krug/mysquad/releases/latest/download/latest.json"
      ]
    }
  }
}
