{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "presentation-*"],
  "permissions": [
    "core:default",
    "core:event:default",
    "opener:default",
    "dialog:default",
    "deep-link:default",
    "sharekit:default",
    "updater:default",
    "process:allow-restart"
  ]
}
